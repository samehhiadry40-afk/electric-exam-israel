// Firestore security rules for electric-exam-israel.
//
// HOW TO USE:
//   1) Open Firebase Console → Firestore Database → Rules tab
//   2) Replace the file in the editor with the contents below
//   3) Click "Publish"
//
// What these rules do:
//   - Each user can read/write ONLY their own document at users/{their_uid}.
//   - Anonymous (unauthenticated) requests are denied.
//   - Anyone trying to access another user's data is denied.
//
// The Firebase API key in firebaseConfig is public by design — these rules
// (NOT the API key) are what actually protect the data.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Read & write only your own document.
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
